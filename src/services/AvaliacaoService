const Avaliacao = require('../models/Avaliacao');

class AvaliacaoService {
  async registrarAvaliacao(dados) {
    // Lógica de negócio: define o risco baseado na pontuação automaticamente
    if (dados.pontuacao >= 8) dados.risco = 'Grave';
    else if (dados.pontuacao >= 5) dados.risco = 'Moderado';
    else dados.risco = 'Leve';

    return await Avaliacao.create(dados);
  }

  async buscarProgressoPaciente(pacienteId) {
    const avaliacoes = await Avaliacao.findAll({
      where: { pacienteId },
      order: [['data', 'ASC']],
      attributes: ['data', 'pontuacao']
    });

    // Formata os dados para o formato do Google Charts: [['Mês', Valor], ...]
    return avaliacoes.map(av => {
      const dataFormatada = new Intl.DateTimeFormat('pt-BR', { month: 'short' }).format(new Date(av.data));
      return [dataFormatada, av.pontuacao];
    });
  }
}

module.exports = new AvaliacaoService();